# Copy to .env and fill in. NEVER commit the real .env.

# Required: clients must send this in the `Authentication-API-Key` header.
AUTHENTICATION_API_KEY=change-me

# Roboflow model keys (each endpoint only needs its own; the booth pipeline
# needs none). Read lazily on first use so the app boots without them.
ROBOFLOW_ICON_API_KEY=        # used by /predict
ROBOFLOW_TRAIL_API_KEY=       # used by /predict and /debug_predict
ROBOFLOW_HALL_API_KEY=        # used by /hall_with_booth_predict

# Booth pipeline defaults (overridable per request via fp_policy form field).
BOOTH_DPI=250
BOOTH_FP_POLICY=shape

# Hall raster downscale cap before Roboflow inference.
HALL_RASTER_MAX_EDGE=2048

# Keep S3 writeback OFF (hard constraint). Private-S3 *reads* still work when
# AWS creds are present, for s3:// image/pdf URLs.
S3_WRITEBACK_ENABLED=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
